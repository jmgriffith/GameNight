# Disable directory listing
Options -Indexes

# Route favicon.ico requests to favicon.php (serves the uploaded site icon)
RewriteEngine On
RewriteRule ^s/([a-zA-Z0-9]+)$ /s.php?code=$1 [L,QSA]
RewriteRule ^favicon\.ico$ /favicon.php [L,R=302]
# Serve the XML sitemap (generated by sitemap.php) at /sitemap.xml
RewriteRule ^sitemap\.xml$ /sitemap.php [L]
# Public read-only API discovery: /api/v1 or /api/v1/ → /api/v1/index.php (no auth needed)
# Order matters: this must come before the catch-all <endpoint> rule below.
RewriteRule ^api/v1/?$ /api/v1/index.php [L,QSA]
# Per-resource API endpoints: /api/v1/events/123 → /api/v1/events.php?id=123
# Sub-resource:               /api/v1/events/123/invites → /api/v1/events.php?id=123&sub=invites
# Per-invitee:                /api/v1/events/123/invites/45 → /api/v1/events.php?id=123&sub=invites&invitee=45
# Must come before the catch-all <endpoint>.php rule. Order: deepest first.
RewriteRule ^api/v1/events/(\d+)/invites/(\d+)/?$ /api/v1/events.php?id=$1&sub=invites&invitee=$2 [L,QSA]
RewriteRule ^api/v1/events/(\d+)/invites/?$ /api/v1/events.php?id=$1&sub=invites [L,QSA]
RewriteRule ^api/v1/events/(\d+)/?$ /api/v1/events.php?id=$1 [L,QSA]
# /api/v1/posts/{id}    → posts.php?id={id}
RewriteRule ^api/v1/posts/(\d+)/?$ /api/v1/posts.php?id=$1 [L,QSA]
# /api/v1/members/{user_id} → members.php?id={user_id}
RewriteRule ^api/v1/members/(\d+)/?$ /api/v1/members.php?id=$1 [L,QSA]
# /api/v1/pending-contacts/{member_id} → pending_contacts.php?id={member_id}
RewriteRule ^api/v1/pending-contacts/(\d+)/?$ /api/v1/pending_contacts.php?id=$1 [L,QSA]
# Public API: /api/v1/<endpoint> → /api/v1/<endpoint>.php
RewriteRule ^api/v1/([a-z]+)/?$ /api/v1/$1.php [L,QSA]

# Hide PHP errors from the browser
php_flag display_errors Off

# Block direct web access to internal/partial PHP files
<FilesMatch "^(auth|db|_nav|_footer|config|mail)\.php$">
    Require all denied
</FilesMatch>

# Block direct web access to API partials (api/_auth.php, api/_response.php, api/_time.php).
# Endpoints under /api/v1/ are reached only through the rewrite rule above.
<FilesMatch "^_(auth|response|time)\.php$">
    Require all denied
</FilesMatch>

# Block any file named config.php anywhere in the webroot (defense-in-depth)
<Files "config.php">
    Require all denied
</Files>