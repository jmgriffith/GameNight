# Credentials — never commit the real config
config/config.php

# Compose env file — holds the shared WAHA_WEBHOOK_TOKEN secret
.env

# SQLite database
db/

# Claude Code settings (may contain passwords/keys)
.claude/

# Docker / server deployment files (server-specific, not for publishing)
deploy.sh
deploy.bat
deploy.ps1

# Local helper scripts
commit.sh

# Sample data
www/sample_users.csv

# Runtime user-uploaded files (not source)
www/uploads/

# Backups
www/_backups/

# PHP vendor dependencies (downloaded by docker-entrypoint.sh on first start)
www/vendor/

# Third-party DB admin tools (downloaded by docker-entrypoint.sh on first start)
www/phpadmin/phpliteadmin.php

# WAHA WhatsApp session data
waha_data/
